# Ascend — environment variables
# Copy to `.env.local` for local dev. In production, set these in
# Netlify → Site configuration → Environment variables.
#
# Leave BOTH blank/absent to run in local (per-device) mode.
# Set BOTH to enable the cloud backend (cross-device accounts + leaderboards).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Only this email can access Owner Mode / the admin dashboard.
VITE_OWNER_EMAIL=
